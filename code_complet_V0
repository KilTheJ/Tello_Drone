def reconstruct_from_velocity(df):
    """
    Reconstruction simple par intégration des vitesses body-frame supposées proches monde-frame.
    Limite : si le drone tourne beaucoup, cette hypothèse casse.
    Donc on corrige avec yaw.
    """
    out = df.copy()

    yaw_rad = np.deg2rad(out["yaw_unwrapped_deg"].fillna(0.0).to_numpy())
    vx_body = out["vx_mps"].fillna(0.0).to_numpy()
    vy_body = out["vy_mps"].fillna(0.0).to_numpy()
    vz = out["vz_mps"].fillna(0.0).to_numpy()
    dt = out["dt"].fillna(DEFAULT_DT).to_numpy()

    # rotation body -> monde dans le plan XY avec yaw
    vx_world = vx_body * np.cos(yaw_rad) - vy_body * np.sin(yaw_rad)
    vy_world = vx_body * np.sin(yaw_rad) + vy_body * np.cos(yaw_rad)

    x = np.cumsum(vx_world * dt)
    y = np.cumsum(vy_world * dt)
    z = np.cumsum(vz * dt)

    out["x_vel_m"] = x
    out["y_vel_m"] = y
    out["z_vel_m"] = z

    return out


def reconstruct_from_acceleration(df, accel_scale=9.81):
    """
    Reconstruction très expérimentale depuis accéléromètre.
    L'IMU seule dérive vite.
    accel_scale permet de convertir si agx/agy/agz sont en g approximatifs.
    """
    out = df.copy()

    ax = out["agx"].fillna(0.0).to_numpy() * accel_scale
    ay = out["agy"].fillna(0.0).to_numpy() * accel_scale
    az = out["agz"].fillna(0.0).to_numpy() * accel_scale
    dt = out["dt"].fillna(DEFAULT_DT).to_numpy()

    vx = np.cumsum(ax * dt)
    vy = np.cumsum(ay * dt)
    vz = np.cumsum(az * dt)

    x = np.cumsum(vx * dt)
    y = np.cumsum(vy * dt)
    z = np.cumsum(vz * dt)

    out["vx_imu_mps"] = vx
    out["vy_imu_mps"] = vy
    out["vz_imu_mps"] = vz
    out["x_imu_m"] = x
    out["y_imu_m"] = y
    out["z_imu_m"] = z

    return out


def fuse_altitude_tof_height(df):
    """
    Fusion simple hauteur h et ToF avec moyenne pondérée + Kalman 1D
    """
    out = df.copy()

    z_h = out["h_m"].to_numpy()
    z_tof = out["tof_m"].to_numpy()

    z_fused = []
    for a, b in zip(z_h, z_tof):
        vals = []
        w = []
        if np.isfinite(a):
            vals.append(a)
            w.append(0.4)
        if np.isfinite(b):
            vals.append(b)
            w.append(0.6)

        if len(vals) == 0:
            z_fused.append(np.nan)
        else:
            z_fused.append(np.average(vals, weights=w))

    out["z_meas_fused_m"] = z_fused

    kal = Kalman1D(dt=float(np.nanmedian(out["dt"].to_numpy())))
    z_est = []
    vz_est = []
    for z in out["z_meas_fused_m"].to_numpy():
        p, v = kal.step(z if np.isfinite(z) else np.nan)
        z_est.append(p)
        vz_est.append(v)

    out["z_kalman_m"] = z_est
    out["vz_kalman_mps"] = vz_est
    return out


def fuse_xy_with_kalman(df):
    """
    On reconstruit d'abord x,y par vitesses, puis on les lisse via un Kalman 2D.
    """
    out = reconstruct_from_velocity(df)

    zx = out["x_vel_m"].to_numpy()
    zy = out["y_vel_m"].to_numpy()

    dt = float(np.nanmedian(out["dt"].to_numpy()))
    kf = Kalman2DPosition(dt=dt)

    xs, ys, vxs, vys = [], [], [], []
    for x, y in zip(zx, zy):
        state = kf.step(x, y)
        xs.append(state[0])
        ys.append(state[1])
        vxs.append(state[2])
        vys.append(state[3])

    out["x_kalman_m"] = xs
    out["y_kalman_m"] = ys
    out["vx_kalman_mps"] = vxs
    out["vy_kalman_mps"] = vys

    return out


