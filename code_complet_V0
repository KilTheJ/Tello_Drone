def create_tracker():
    """
    Compatibilité OpenCV selon version.
    """
    tracker = None

    if hasattr(cv2, "TrackerCSRT_create"):
        tracker = cv2.TrackerCSRT_create()
    elif hasattr(cv2, "legacy") and hasattr(cv2.legacy, "TrackerCSRT_create"):
        tracker = cv2.legacy.TrackerCSRT_create()
    elif hasattr(cv2, "TrackerKCF_create"):
        tracker = cv2.TrackerKCF_create()
    elif hasattr(cv2, "legacy") and hasattr(cv2.legacy, "TrackerKCF_create"):
        tracker = cv2.legacy.TrackerKCF_create()

    return tracker


def detect_and_track_people(video_path=VIDEO_FILE, out_video=None, display=True):
    video_path = Path(video_path)
    if not video_path.exists():
        print(f"[ERREUR] Vidéo introuvable : {video_path}")
        return None

    if out_video is None:
        out_video = ANALYSIS_DIR / "people_tracking.avi"
    out_video = Path(out_video)

    cap = cv2.VideoCapture(str(video_path))
    if not cap.isOpened():
        print("[ERREUR] Impossible d'ouvrir la vidéo.")
        return None

    hog = cv2.HOGDescriptor()
    hog.setSVMDetector(cv2.HOGDescriptor_getDefaultPeopleDetector())

    tracker = None
    track_box = None
    frame_idx = 0
    records = []

    fps = cap.get(cv2.CAP_PROP_FPS)
    if fps is None or fps <= 1:
        fps = 25.0

    width = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH) or 960)
    height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT) or 720)
    fourcc = cv2.VideoWriter_fourcc(*"XVID")
    writer = cv2.VideoWriter(str(out_video), fourcc, fps, (width, height))

    while True:
        ok, frame = cap.read()
        if not ok:
            break

        frame_idx += 1
        timestamp = frame_idx / fps

        display_frame = frame.copy()

        # Toutes les 20 frames, on redétecte pour éviter de suivre le néant cosmique
        if tracker is None or frame_idx % 20 == 1:
            rects, _ = hog.detectMultiScale(
                frame,
                winStride=(8, 8),
                padding=(8, 8),
                scale=1.05
            )

            if len(rects) > 0:
                # On garde la plus grande boîte
                rects = sorted(rects, key=lambda r: r[2] * r[3], reverse=True)
                x, y, w, h = rects[0]
                tracker = create_tracker()
                if tracker is not None:
                    tracker.init(frame, (x, y, w, h))
                    track_box = (x, y, w, h)

        else:
            ok_track, box = tracker.update(frame)
            if ok_track:
                track_box = box
            else:
                tracker = None
                track_box = None

        if track_box is not None:
            x, y, w, h = [int(v) for v in track_box]
            cx = x + w / 2
            cy = y + h / 2

            cv2.rectangle(display_frame, (x, y), (x + w, y + h), (0, 255, 0), 2)
            cv2.putText(
                display_frame,
                "Person tracked",
                (x, max(20, y - 10)),
                cv2.FONT_HERSHEY_SIMPLEX,
                0.7,
                (0, 255, 0),
                2
            )

            records.append({
                "frame": frame_idx,
                "t_video_s": timestamp,
                "x": x,
                "y": y,
                "w": w,
                "h": h,
                "cx": cx,
                "cy": cy
            })

        writer.write(display_frame)

        if display:
            cv2.imshow("People Tracking", display_frame)
            key = cv2.waitKey(1) & 0xFF
            if key == 27:
                break

    cap.release()
    writer.release()
    cv2.destroyAllWindows()

    df_track = pd.DataFrame(records)
    if not df_track.empty:
        df_track.to_csv(ANALYSIS_DIR / "people_tracking.csv", index=False)
        print(f"[INFO] Tracking exporté vers {ANALYSIS_DIR / 'people_tracking.csv'}")
    else:
        print("[INFO] Aucune personne détectée/suivie.")

    return df_track


