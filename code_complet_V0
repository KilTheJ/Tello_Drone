class TelloTelemetryRecorder:
    def __init__(self, csv_path=TELEMETRY_CSV, jsonl_path=TELEMETRY_JSONL):
        self.csv_path = Path(csv_path)
        self.jsonl_path = Path(jsonl_path)
        self.stop_event = threading.Event()
        self.thread = None
        self.writer = None
        self.csv_file = None
        self.jsonl_file = None
        self.sock = None
        self.fieldnames = None
        self.sample_count = 0

    def start(self):
        self.thread = threading.Thread(target=self._run, daemon=True)
        self.thread.start()

    def stop(self):
        self.stop_event.set()
        time.sleep(0.3)
        if self.sock is not None:
            try:
                self.sock.close()
            except Exception:
                pass
        if self.csv_file is not None:
            try:
                self.csv_file.close()
            except Exception:
                pass
        if self.jsonl_file is not None:
            try:
                self.jsonl_file.close()
            except Exception:
                pass

    def _run(self):
        self.sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        self.sock.bind(("", STATE_PORT))
        self.sock.settimeout(0.5)

        self.csv_file = open(self.csv_path, "w", newline="", encoding="utf-8")
        self.jsonl_file = open(self.jsonl_path, "w", encoding="utf-8")

        print(f"[INFO] Ecoute télémétrie sur UDP {STATE_PORT}")

        while not self.stop_event.is_set():
            try:
                data, _ = self.sock.recvfrom(4096)
            except socket.timeout:
                continue
            except OSError:
                break

            raw = data.decode("utf-8", errors="ignore").strip()
            state = parse_state_string(raw)
            row = {"timestamp": now_ts(), "raw_state": raw}
            row.update(state)

            if self.writer is None:
                self.fieldnames = list(row.keys())
                self.writer = csv.DictWriter(self.csv_file, fieldnames=self.fieldnames)
                self.writer.writeheader()

            for k in self.fieldnames:
                if k not in row:
                    row[k] = np.nan

            self.writer.writerow(row)
            self.csv_file.flush()

            self.jsonl_file.write(json.dumps(row, ensure_ascii=False) + "\n")
            self.jsonl_file.flush()

            self.sample_count += 1

        print(f"[INFO] Fin acquisition télémétrie. Echantillons: {self.sample_count}")


class TelloCommander:
    def __init__(self, tello_ip=TELLO_IP, cmd_port=CMD_PORT):
        self.addr = (tello_ip, cmd_port)
        self.sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        self.sock.settimeout(5)

    def send(self, cmd, wait_response=True):
        print(f"[CMD] {cmd}")
        self.sock.sendto(cmd.encode("utf-8"), self.addr)
        if wait_response:
            try:
                resp, _ = self.sock.recvfrom(1024)
                text = resp.decode("utf-8", errors="ignore").strip()
                print(f"[RESP] {text}")
                return text
            except socket.timeout:
                print("[WARN] Pas de réponse")
                return None
        return None

    def close(self):
        try:
            self.sock.close()
        except Exception:
            pass


class TelloVideoRecorder:
    def __init__(self, output_path=VIDEO_FILE, max_seconds=MAX_VIDEO_SECONDS):
        self.output_path = Path(output_path)
        self.max_seconds = max_seconds
        self.stop_event = threading.Event()
        self.thread = None
        self.frame_count = 0

    def start(self):
        self.thread = threading.Thread(target=self._run, daemon=True)
        self.thread.start()

    def stop(self):
        self.stop_event.set()

    def _run(self):
        print("[INFO] Ouverture flux vidéo...")
        cap = cv2.VideoCapture(VIDEO_URL, cv2.CAP_FFMPEG)

        if not cap.isOpened():
            print("[WARN] Impossible d'ouvrir le flux vidéo Tello.")
            return

        fps = cap.get(cv2.CAP_PROP_FPS)
        if fps is None or fps <= 1:
            fps = 30.0

        width = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH) or 960)
        height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT) or 720)

        fourcc = cv2.VideoWriter_fourcc(*"XVID")
        out = cv2.VideoWriter(str(self.output_path), fourcc, fps, (width, height))

        t0 = time.time()

        while not self.stop_event.is_set():
            ok, frame = cap.read()
            if not ok:
                continue

            out.write(frame)
            self.frame_count += 1

            cv2.imshow("Tello Video", frame)
            key = cv2.waitKey(1) & 0xFF
            if key == 27:
                break

            if time.time() - t0 > self.max_seconds:
                break

        cap.release()
        out.release()
        cv2.destroyAllWindows()
        print(f"[INFO] Vidéo enregistrée : {self.output_path} ({self.frame_count} frames)")


