def acquire_tello_data(with_video=False):
    rec = TelloTelemetryRecorder()
    cmd = TelloCommander()
    video = None

    try:
        rec.start()
        time.sleep(0.5)

        cmd.send("command")
        time.sleep(1)

        if with_video:
            cmd.send("streamon")
            time.sleep(1)
            video = TelloVideoRecorder()
            video.start()

        if AUTO_FLIGHT:
            automated_demo_flight(cmd)
        else:
            manual_command_loop(cmd)

    finally:
        if video is not None:
            video.stop()
            time.sleep(1)
        try:
            cmd.send("streamoff", wait_response=False)
        except Exception:
            pass
        rec.stop()
        cmd.close()


