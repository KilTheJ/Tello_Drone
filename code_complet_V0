def analyze_telemetry(csv_path=TELEMETRY_CSV, outdir=ANALYSIS_DIR):
    if not Path(csv_path).exists():
        print(f"[ERREUR] Fichier introuvable : {csv_path}")
        return None

    df = load_telemetry_csv(csv_path)

    # lissages simples
    df["bat_ma"] = moving_average(df["bat"], 5)
    df["temp_ma"] = moving_average(df["temp_mean"], 5)
    df["agx_smooth"] = savgol_smooth(df["agx"], 11, 2)
    df["agy_smooth"] = savgol_smooth(df["agy"], 11, 2)
    df["agz_smooth"] = savgol_smooth(df["agz"], 11, 2)

    # fusions
    df = fuse_altitude_tof_height(df)
    df = fuse_xy_with_kalman(df)
    df = reconstruct_from_acceleration(df)

    # résumé
    summary = flight_summary(df)
    summary.to_csv(outdir / "summary.csv", index=False)
    df.to_csv(outdir / "telemetry_enriched.csv", index=False)

    print("\n===== RESUME DU VOL =====")
    print(summary.to_string(index=False))

    # figures
    plot_battery_temperature(df, outdir)
    plot_attitude(df, outdir)
    plot_velocity(df, outdir)
    plot_imu(df, outdir)
    plot_altitude_fusion(df, outdir)
    plot_trajectory_2d(df, outdir)
    plot_trajectory_3d(df, outdir)

    export_plotly_graphs(df, outdir)

    return df


