def now_ts():
    return time.time()


def safe_float(x, default=np.nan):
    try:
        return float(x)
    except Exception:
        return default


def safe_int(x, default=np.nan):
    try:
        return int(x)
    except Exception:
        return default


def ensure_numeric(df, columns):
    for c in columns:
        if c in df.columns:
            df[c] = pd.to_numeric(df[c], errors="coerce")
    return df


def angle_deg_to_rad(series):
    return np.deg2rad(pd.to_numeric(series, errors="coerce"))


def unwrap_deg(deg_series):
    rad = np.deg2rad(pd.to_numeric(deg_series, errors="coerce"))
    unwrapped = np.unwrap(rad)
    return np.rad2deg(unwrapped)


def moving_average(series, window=5):
    s = pd.to_numeric(series, errors="coerce")
    return s.rolling(window=window, center=True, min_periods=1).mean()


def savgol_smooth(series, window=11, poly=2):
    s = pd.to_numeric(series, errors="coerce").astype(float)
    valid = s.notna().sum()
    if valid < max(window, poly + 2):
        return s.copy()
    x = s.interpolate(limit_direction="both").to_numpy()
    if window % 2 == 0:
        window += 1
    if window >= len(x):
        window = len(x) - 1 if len(x) % 2 == 0 else len(x)
    if window < 3:
        return s
    y = savgol_filter(x, window_length=window, polyorder=poly, mode="interp")
    return pd.Series(y, index=s.index)


