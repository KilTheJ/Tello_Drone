def flight_summary(df):
    out = {}
    out["samples"] = int(len(df))
    out["duration_s"] = float(df["t"].max() - df["t"].min()) if len(df) > 1 else 0.0
    out["battery_start_pct"] = float(df["bat"].dropna().iloc[0]) if df["bat"].notna().any() else np.nan
    out["battery_end_pct"] = float(df["bat"].dropna().iloc[-1]) if df["bat"].notna().any() else np.nan
    out["battery_drop_pct"] = (
        out["battery_start_pct"] - out["battery_end_pct"]
        if np.isfinite(out["battery_start_pct"]) and np.isfinite(out["battery_end_pct"])
        else np.nan
    )
    out["max_height_m"] = float(df["h_m"].max()) if df["h_m"].notna().any() else np.nan
    out["max_tof_m"] = float(df["tof_m"].max()) if df["tof_m"].notna().any() else np.nan
    out["max_speed_xy_mps"] = float(df["vxy_mps"].max()) if df["vxy_mps"].notna().any() else np.nan
    out["max_speed_xyz_mps"] = float(df["vxyz_mps"].max()) if df["vxyz_mps"].notna().any() else np.nan
    out["temp_mean_min"] = float(df["temp_mean"].min()) if df["temp_mean"].notna().any() else np.nan
    out["temp_mean_max"] = float(df["temp_mean"].max()) if df["temp_mean"].notna().any() else np.nan
    return pd.DataFrame([out])


