def align_video_tracking_with_telemetry(track_df, telemetry_df):
    """
    Version simple :
    - aligne le temps vidéo sur le temps du vol
    - calcule des colonnes combinées pour analyse exploratoire

    Pour une vraie fusion vision/odometrie robuste, il faudrait :
    - synchro précise temps vidéo / temps drone
    - calibration caméra
    - estimation pose / optical flow / SLAM
    """
    if track_df is None or track_df.empty or telemetry_df is None or telemetry_df.empty:
        return None

    tel = telemetry_df.copy()
    trk = track_df.copy()

    # alignement basique
    tel["t_round"] = tel["t"].round(1)
    trk["t_round"] = trk["t_video_s"].round(1)

    merged = pd.merge_asof(
        trk.sort_values("t_round"),
        tel.sort_values("t_round"),
        on="t_round",
        direction="nearest"
    )

    merged["image_offset_x"] = merged["cx"] - merged["cx"].median()
    merged["image_offset_y"] = merged["cy"] - merged["cy"].median()

    merged.to_csv(ANALYSIS_DIR / "vision_telemetry_fused.csv", index=False)
    return merged


