def parse_state_string(state_str):
    """
    Exemple :
    pitch:0;roll:0;yaw:0;vgx:0;vgy:0;vgz:0;templ:65;temph:67;tof:10;h:0;bat:90;baro:12.34;time:0;agx:1.0;agy:2.0;agz:-3.0;
    """
    out = {}

    if not isinstance(state_str, str):
        return out

    chunks = state_str.strip().split(";")
    for chunk in chunks:
        if ":" not in chunk:
            continue
        key, value = chunk.split(":", 1)
        key = key.strip()
        value = value.strip()

        if key == "mpry":
            parts = value.split(",")
            if len(parts) == 3:
                out["mission_pad_m"] = safe_float(parts[0])
                out["mission_pad_p"] = safe_float(parts[1])
                out["mission_pad_r"] = safe_float(parts[2])
            else:
                out[key] = value
            continue

        if "," in value:
            out[key] = value
            continue

        try:
            if "." in value or "e" in value.lower():
                out[key] = float(value)
            else:
                out[key] = int(value)
        except Exception:
            out[key] = value

    return out


def load_telemetry_csv(csv_path):
    df = pd.read_csv(csv_path)

    for col in STATE_FIELDS_EXPECTED:
        if col not in df.columns:
            df[col] = np.nan

    numeric_cols = [
        "timestamp", "pitch", "roll", "yaw",
        "vgx", "vgy", "vgz",
        "templ", "temph",
        "tof", "h", "bat", "baro", "time",
        "agx", "agy", "agz",
        "mid", "x", "y", "z",
        "mission_pad_m", "mission_pad_p", "mission_pad_r"
    ]
    df = ensure_numeric(df, numeric_cols)

    # temps relatif
    if "timestamp" in df.columns and df["timestamp"].notna().any():
        df["t"] = df["timestamp"] - df["timestamp"].iloc[0]
    elif "time" in df.columns and df["time"].notna().any():
        df["t"] = df["time"] - df["time"].iloc[0]
    else:
        df["t"] = np.arange(len(df)) * DEFAULT_DT

    # pas de temps
    df["dt"] = df["t"].diff().fillna(DEFAULT_DT)
    df.loc[df["dt"] <= 0, "dt"] = DEFAULT_DT

    # températures
    df["temp_mean"] = pd.concat(
        [df["templ"], df["temph"]], axis=1
    ).mean(axis=1)

    # vitesses en m/s
    df["vx_mps"] = df["vgx"] / 100.0
    df["vy_mps"] = df["vgy"] / 100.0
    df["vz_mps"] = df["vgz"] / 100.0

    df["vxy_mps"] = np.sqrt(df["vx_mps"] ** 2 + df["vy_mps"] ** 2)
    df["vxyz_mps"] = np.sqrt(df["vx_mps"] ** 2 + df["vy_mps"] ** 2 + df["vz_mps"] ** 2)

    # hauteurs
    df["h_m"] = df["h"] / 100.0
    df["tof_m"] = df["tof"] / 100.0

    # angles unwrap pour éviter les sauts ±180
    df["yaw_unwrapped_deg"] = unwrap_deg(df["yaw"])

    return df


