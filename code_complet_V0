# =============================================================================

class Kalman1D:
    """
    Etat : [position, vitesse]
    Mesure : position
    """
    def __init__(self, dt=0.05, q_pos=0.01, q_vel=0.1, r_meas=0.5):
        self.dt = dt
        self.A = np.array([[1, dt],
                           [0, 1]], dtype=float)
        self.H = np.array([[1, 0]], dtype=float)
        self.Q = np.array([[q_pos, 0],
                           [0, q_vel]], dtype=float)
        self.R = np.array([[r_meas]], dtype=float)
        self.P = np.eye(2, dtype=float)
        self.x = np.zeros((2, 1), dtype=float)

    def predict(self):
        self.x = self.A @ self.x
        self.P = self.A @ self.P @ self.A.T + self.Q

    def update(self, z):
        z = np.array([[z]], dtype=float)
        y = z - self.H @ self.x
        S = self.H @ self.P @ self.H.T + self.R
        K = self.P @ self.H.T @ np.linalg.inv(S)
        self.x = self.x + K @ y
        I = np.eye(2)
        self.P = (I - K @ self.H) @ self.P

    def step(self, z):
        self.predict()
        if np.isfinite(z):
            self.update(z)
        return float(self.x[0, 0]), float(self.x[1, 0])


class Kalman2DPosition:
    """
    Etat : [x, y, vx, vy]
    Mesure : [x, y]
    """
    def __init__(self, dt=0.05, q=0.05, r=0.5):
        self.dt = dt
        self.A = np.array([
            [1, 0, dt, 0],
            [0, 1, 0, dt],
            [0, 0, 1, 0],
            [0, 0, 0, 1]
        ], dtype=float)

        self.H = np.array([
            [1, 0, 0, 0],
            [0, 1, 0, 0]
        ], dtype=float)

        self.Q = q * np.eye(4)
        self.R = r * np.eye(2)
        self.P = np.eye(4)
        self.x = np.zeros((4, 1), dtype=float)

    def predict(self):
        self.x = self.A @ self.x
        self.P = self.A @ self.P @ self.A.T + self.Q

    def update(self, z):
        z = np.array(z, dtype=float).reshape(2, 1)
        y = z - self.H @ self.x
        S = self.H @ self.P @ self.H.T + self.R
        K = self.P @ self.H.T @ np.linalg.inv(S)
        self.x = self.x + K @ y
        I = np.eye(4)
        self.P = (I - K @ self.H) @ self.P

    def step(self, zx, zy):
        self.predict()
        if np.isfinite(zx) and np.isfinite(zy):
            self.update([zx, zy])
        return self.x.flatten()


